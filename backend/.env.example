# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection URI
# Replace this with your actual MongoDB Atlas connection string
MONGODB_URl=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/pixel_realms?retryWrites=true&w=majority

# Gemini API Key
# Replace this with your secure Gemini API key from Google AI Studio
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# CORS Security Allowed Origin
# Set this to your GitHub Pages URL in production, or '*' for testing
CORS_ORIGIN=https://your-github-username.github.io
